RewriteEngine On
RewriteBase /

RewriteCond %{HTTP_HOST} ^www. [NC]
RewriteRule ^(.*)$ https://pgm-engineering.com/$1 [L,R=301]

RewriteCond %{SERVER_PORT} 80 
RewriteRule ^(.*)$ https://pgm-engineering.com/$1 [R=301,L]

RewriteRule ^polityka-prywatnosci$ strony.php?id=6 [L]
RewriteRule ^maszyny-poligraficzne$ strony.php?id=7 [L]
RewriteRule ^serwis-transport$ strony.php?id=8 [L]
RewriteRule ^doradztwo$ strony.php?id=9 [L]
RewriteRule ^galeria$ strony.php?id=10 [L]

RewriteRule ^kontakt$ kontaktznami.php?id=11 [L]

RewriteRule ^o-nas$ strony.php?id=12 [L]
RewriteRule ^relokacje-serwis-maszyn$ strony.php?id=13 [L]
RewriteRule ^maszyny-dla-poligrafii$ strony.php?id=14 [L]
RewriteRule ^zaladunki-rozladunki$ strony.php?id=15 [L]
RewriteRule ^wynajem-widlakow$ strony.php?id=16 [L]

RewriteRule ^aktualnosci$ https://pgm-engineering.com/$1 [R=301,L]

RewriteRule ^pl$ index.php?jezyk=1 [L]
RewriteRule ^en$ index.php?jezyk=2 [L]
RewriteRule ^de$ index.php?jezyk=3 [L]

RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ https://pgm-engineering.com [L,R=301]
